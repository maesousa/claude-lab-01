{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "chargeback-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "chargeback-db",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "chargeback-app/docker-compose.yml", "up", "db"],
      "port": 5432
    },
    {
      "name": "prisma-studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:studio"],
      "port": 5555
    }
  ]
}
